<Window x:Class="Podcastner.DictionaryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dictionary"
        Width="900"
        Height="600"
        Background="#181818">


    <Window.Resources>



        <!-- ===================== PALETA ===================== -->
        <SolidColorBrush x:Key="AccentBrush" Color="#1DB954"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#1ED760"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#181818"/>
        <SolidColorBrush x:Key="CardBrush" Color="#242424"/>
        <SolidColorBrush x:Key="CardHoverBrush" Color="#2E2E2E"/>
        <SolidColorBrush x:Key="CardSelectedBrush" Color="#1DB954"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#B3B3B3"/>
        <SolidColorBrush x:Key="BorderBrush2" Color="#2A2A2A"/>



        <!-- ===================== CAJA DE BÚSQUEDA ===================== -->
        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#242424"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="3"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" CornerRadius="18">
                            <ScrollViewer x:Name="PART_ContentHost"
                                  Margin="{TemplateBinding Padding}"
                                  VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <!-- Botón principal Play/Pause, más grande y verde -->
        <Style x:Key="PlayButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="60"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>





    </Window.Resources>
    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <StackPanel Grid.Row="0"
                Orientation="Horizontal" Margin="0,0,0,494" Grid.RowSpan="3">

            <TextBox
            x:Name="WordBox"
            Width="250"
            Height="40"
            Style="{StaticResource SearchBoxStyle}"/>

            <Button
            Content="Buscar"
            Width="140"
            Height="45"
            Margin="10,0,0,0"
            Click="BuscarPalabra_Click"
            Style="{StaticResource PlayButtonStyle}"/>

        </StackPanel>


        <TextBox
        Grid.Row="2"
        x:Name="DictionaryResult"
        Background="#242424"
        Foreground="White"
        BorderThickness="0"
        FontSize="14"
        Padding="10"
        AcceptsReturn="True"
        IsReadOnly="True"
        TextWrapping="Wrap"
        VerticalScrollBarVisibility="Auto" Margin="0,83,0,0"/>

    </Grid>

</Window>
