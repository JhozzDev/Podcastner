<Window x:Class="Podcastner.FavoritesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Favoritos"
        Width="900"
        Height="600"
        Background="#181818">


    <Window.Resources>



        <!-- ===================== PALETA ===================== -->
        <SolidColorBrush x:Key="AccentBrush" Color="#1DB954"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#1ED760"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#181818"/>
        <SolidColorBrush x:Key="CardBrush" Color="#242424"/>
        <SolidColorBrush x:Key="CardHoverBrush" Color="#2E2E2E"/>
        <SolidColorBrush x:Key="CardSelectedBrush" Color="#1DB954"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#B3B3B3"/>
        <SolidColorBrush x:Key="BorderBrush2" Color="#2A2A2A"/>


        <!-- ===================== TARJETA DE PODCAST ===================== -->
        <Style x:Key="PodcastItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                              Background="{StaticResource CardBrush}"
                              CornerRadius="10"
                              Padding="10"
                              BorderThickness="2"
                              BorderBrush="Transparent">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource CardHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="ItemBorder" Property="Background" Value="#1A2E22"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

 
        <!-- ===================== BOTONES CIRCULARES DEL REPRODUCTOR ===================== -->
        <Style x:Key="PlayerButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="Margin" Value="8,0"/>
            <Setter Property="Background" Value="#242424"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="23">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#333333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>



    </Window.Resources>



    <Grid>

        <ListBox x:Name="FavoritesList"
                 Background="Transparent">

            <ListBox.ItemTemplate>
                <DataTemplate>

                    <StackPanel Orientation="Horizontal"
                                Margin="10">

                        <Image Width="60"
                               Height="60"
                               Source="{Binding ImageUrl}"/>

                        <TextBlock
                            Text="{Binding Name}"
                            Foreground="White"
                            FontSize="18"
                            Margin="15,0,0,0"
                            VerticalAlignment="Center"/>

                        <Button Click="Remove" Style="{StaticResource PlayerButtonStyle}" Content="X"/>

                    </StackPanel>

                </DataTemplate>
            </ListBox.ItemTemplate>

        </ListBox>

    </Grid>

</Window>