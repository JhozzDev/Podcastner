<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" x:Class="Podcastner.MainWindow"
        Title="Podcastner"
        Height="780"
        Width="1280"
        MinHeight="600"
        MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#0D0D0D"
        FontFamily="Segoe UI"
        >

    <Window.Resources>
        
        

        <!-- ===================== PALETA ===================== -->
        <SolidColorBrush x:Key="AccentBrush" Color="#1DB954"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#1ED760"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#181818"/>
        <SolidColorBrush x:Key="CardBrush" Color="#242424"/>
        <SolidColorBrush x:Key="CardHoverBrush" Color="#2E2E2E"/>
        <SolidColorBrush x:Key="CardSelectedBrush" Color="#1DB954"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#B3B3B3"/>
        <SolidColorBrush x:Key="BorderBrush2" Color="#2A2A2A"/>

        <!-- ===================== SCROLLBA==================== -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="8"/>
        </Style>

        <!-- ===================== TARJETA DE PODCAST ===================== -->
        <Style x:Key="PodcastItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{StaticResource CardBrush}"
                                CornerRadius="10"
                                Padding="10"
                                BorderThickness="2"
                                BorderBrush="Transparent">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource CardHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="ItemBorder" Property="Background" Value="#1A2E22"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===================== TARJETA DE EPISODIO ===================== -->
        <Style x:Key="EpisodeItemStyle" TargetType="ListBoxItem" BasedOn="{StaticResource PodcastItemStyle}"/>

        <!-- ===================== BOTONES CIRCULARES DEL REPRODUCTOR ===================== -->
        <Style x:Key="PlayerButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="Margin" Value="8,0"/>
            <Setter Property="Background" Value="#242424"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="23">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#333333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botón principal Play/Pause, más grande y verde -->
        <Style x:Key="PlayButtonStyle" TargetType="Button" BasedOn="{StaticResource PlayerButtonStyle}">
            <Setter Property="Width" Value="60"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="30">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>



        <!-- ===================== CAJA DE BÚSQUEDA ===================== -->
        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#242424"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" CornerRadius="18">
                            <ScrollViewer x:Name="PART_ContentHost"
                                  Margin="{TemplateBinding Padding}"
                                  VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        


        <!-- ===================== SLIDER DE PROGRESO ===================== -->
        <Style x:Key="ProgressSliderStyle" TargetType="Slider">
            <Setter Property="Height" Value="20"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Background" Value="{StaticResource BorderBrush2}"/>
            <Setter Property="IsMoveToPointEnabled" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center">
                            <Border x:Name="TrackBg"
                                    Height="4"
                                    CornerRadius="2"
                                    Background="{TemplateBinding Background}"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate>
                                                <Border Height="4" CornerRadius="2"
                                                        Background="{TemplateBinding Foreground}"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                        <RepeatButton.Foreground>
                                            <Binding RelativeSource="{RelativeSource AncestorType=Slider}" Path="Foreground"/>
                                        </RepeatButton.Foreground>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" Background="Transparent" BorderThickness="0"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="14" Height="14">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Fill="{StaticResource AccentBrush}"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>
   

    <Grid Margin="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="110"/>
        </Grid.RowDefinitions>


        <!-- ===================== HEADER ===================== -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="🎧" FontSize="30" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <TextBlock
                    Text="Podcastner"
                    FontSize="28"
                    FontWeight="Bold"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    VerticalAlignment="Center"/>
            </StackPanel>

            <TextBox
                x:Name="SearchBox"
                Grid.Column="1"
                Style="{StaticResource SearchBoxStyle}"
                Width="320"
                Height="36"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Tag="Buscar podcast o episodio..."/>

            <Button x:Name="SearchBtn"
        Style="{StaticResource PlayerButtonStyle}"
        Click="CargarPodcasts"
        Content="🔍"
        ToolTip="Buscar"/>
        </Grid>


        <!-- ===================== CONTENIDO ===================== -->
        <Grid Grid.Row="1" Margin="0,20,0,20">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>


            <!-- ===================== PANEL PODCASTS ===================== -->
            <Border
                Grid.Column="0"
                Background="{StaticResource PanelBrush}"
                CornerRadius="15"
                Padding="16">

                <DockPanel>

                    <TextBlock
                        DockPanel.Dock="Top"
                        Text="Tus podcasts"
                        FontSize="20"
                        FontWeight="Bold"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        Margin="4,0,0,12"/>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ListBox
                            x:Name="PodcastList"
                            Background="Transparent"
                            BorderThickness="0"
                            ItemContainerStyle="{StaticResource PodcastItemStyle}"
                            SelectionChanged="PodcastList_SelectionChanged">

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">

                                        <Border CornerRadius="8" ClipToBounds="True" Width="56" Height="56" Margin="0,0,12,0">
                                            <Image Source="{Binding ImageUrl}" Stretch="UniformToFill"/>
                                        </Border>

                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock
                                                Text="{Binding Name}"
                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                FontSize="15"
                                                FontWeight="SemiBold"
                                                TextTrimming="CharacterEllipsis"
                                                MaxWidth="220"/>
                                            <TextBlock
                                                Text="{Binding TotalEpisodesCount, StringFormat='{}{0} episodios'}"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                FontSize="12"
                                                Margin="0,2,0,0"/>
                                        </StackPanel>

                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>

                        </ListBox>
                    </ScrollViewer>

                </DockPanel>

            </Border>


            <!-- ===================== PANEL DETALLES ===================== -->
            <Border
                Grid.Column="2"
                Background="{StaticResource PanelBrush}"
                CornerRadius="15"
                Padding="24">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- INFO PODCAST -->
                    <StackPanel Orientation="Horizontal">

                        <Border CornerRadius="12" ClipToBounds="True" Width="130" Height="130" Margin="0,0,20,0" Background="#242424">
                            <Image x:Name="PodcastImage" Stretch="UniformToFill"/>
                        </Border>

                        <StackPanel VerticalAlignment="Center">

                            <TextBlock
                                x:Name="PodcastTitle"
                                Text="Selecciona un podcast"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                FontSize="28"
                                FontWeight="Bold"
                                TextWrapping="Wrap"/>

                            <TextBlock
                                x:Name="PodcastDescription"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                FontSize="13"
                                TextWrapping="Wrap"
                                Margin="0,8,0,0"
                                MaxHeight="70"/>

                        </StackPanel>

                    </StackPanel>

                    <Separator Grid.Row="1" Background="{StaticResource BorderBrush2}" Margin="0,20,0,10"/>

                    <TextBlock Grid.Row="1"
                               Text="Episodios"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,26,0,0"/>

                    <!-- EPISODIOS -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
                        <ListBox
                            x:Name="EpisodeList"
                            Background="Transparent"
                            BorderThickness="0"
                            ItemContainerStyle="{StaticResource EpisodeItemStyle}"
                            SelectionChanged="EpisodeList_SelectionChanged"
                            d:ItemsSource="{d:SampleData ItemCount=5}">

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Width="38" Height="38" CornerRadius="19"
                                                Background="#1DB954" Margin="0,0,12,0" VerticalAlignment="Top">
                                            <TextBlock Text="▶" Foreground="Black" FontSize="12"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock
                                                Text="{Binding Name}"
                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                FontSize="15"
                                                FontWeight="SemiBold"/>
                                            <TextBlock
                                                Text="{Binding Description}"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                FontSize="12"
                                                TextWrapping="Wrap"
                                                MaxHeight="34"
                                                Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>

                        </ListBox>
                    </ScrollViewer>

                </Grid>

            </Border>

        </Grid>


        <!-- ===================== REPRODUCTOR ===================== -->
        <Border
            Grid.Row="2"
            Background="{StaticResource PanelBrush}"
            CornerRadius="15"
            Padding="20,12">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="180"/>
                </Grid.ColumnDefinitions>

                <!-- EPISODIO ACTUAL -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="48" Height="48" CornerRadius="8" ClipToBounds="True" Background="#242424" Margin="0,0,10,0">
                        <Image x:Name="NowPlayingImage" Stretch="UniformToFill"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="NowPlayingTitle" Text="Ningún episodio en reproducción"
                                   Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" MaxWidth="190"/>
                        <TextBlock x:Name="NowPlayingPodcast" Text=""
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                    </StackPanel>
                </StackPanel>

                <!-- CONTROLES + PROGRESO -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">

                        <Button x:Name="RewindButton" Style="{StaticResource PlayerButtonStyle}" Content="⏪" ToolTip="Retroceder 10s"/>

                        <Button x:Name="PlayButton" Style="{StaticResource PlayButtonStyle}" Content="▶" Click="Play_Click" ToolTip="Reproducir"/>

                        <Button x:Name="PauseButton" Style="{StaticResource PlayerButtonStyle}" Content="⏸" ToolTip="Pausar"/>

                        <Button x:Name="StopButton" Style="{StaticResource PlayerButtonStyle}" Content="⏹" ToolTip="Detener"/>

                        <Button x:Name="ForwardButton" Style="{StaticResource PlayerButtonStyle}" Content="⏩" ToolTip="Adelantar 10s"/>

                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="TiempoActual" Text="00:00" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" VerticalAlignment="Center" Margin="0,0,10,0"/>

                      
                    <Slider    x:Name="AudioSlider" 
ValueChanged="AudioSlider_ValueChanged"
PreviewMouseDown="AudioSlider_PreviewMouseDown"
PreviewMouseUp="AudioSlider_PreviewMouseUp" Grid.Column="1" Style="{StaticResource ProgressSliderStyle}" Minimum="0" Maximum="100" Value="0"/>
                        <TextBlock x:Name="TiempoTotal" Grid.Column="2" Text="00:00" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"/>

                    </Grid>

                </StackPanel>

            

                <!-- VOLUMEN -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock Text="🔊" Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <Slider x:Name="VolumeSlider" Style="{StaticResource ProgressSliderStyle}" Width="100" Minimum="0" Maximum="100" Value="70" VerticalAlignment="Center"/>
                </StackPanel>

            </Grid>

        </Border>


    </Grid>

</Window>
