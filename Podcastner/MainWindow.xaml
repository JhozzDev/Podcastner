<Window x:Class="Podcastner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Podcastner"
        Height="650"
        Width="1000"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Grid Margin="20">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="90"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock
            Grid.ColumnSpan="2"
            Text="🎧 Podcastner"
            FontSize="32"
            FontWeight="Bold"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"/>

        <!-- Lista de Podcasts -->
        <GroupBox
            Grid.Row="1"
            Header="Podcasts"
            Margin="0,10,10,10">

            <ListBox
                x:Name="PodcastList"
                DisplayMemberPath="Title"/>

        </GroupBox>

        <!-- Panel derecho -->
        <Border
            Grid.Row="1"
            Grid.Column="1"
            Margin="10"
            BorderBrush="Gray"
            BorderThickness="1"
            CornerRadius="10"
            Padding="20">

            <StackPanel>

                <TextBlock
                    x:Name="PodcastTitle"
                    Text="Selecciona un podcast"
                    FontSize="26"
                    FontWeight="Bold"
                    Margin="0,0,0,10"/>

                <TextBlock
                    x:Name="PodcastAuthor"
                    Text=""
                    FontSize="18"
                    Margin="0,0,0,20"/>

                <TextBlock
                    Text="Descripción"
                    FontWeight="Bold"
                    FontSize="16"/>

                <TextBlock
                    x:Name="PodcastDescription"
                    TextWrapping="Wrap"
                    Margin="0,5,0,20"/>

                <TextBlock
                    Text="Captions"
                    FontWeight="Bold"
                    FontSize="16"/>

                <TextBox
                    x:Name="LyricsBox"
                    Height="220"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    IsReadOnly="True"
                    VerticalScrollBarVisibility="Auto"/>

            </StackPanel>

        </Border>

        <!-- Controles -->
        <StackPanel
            Grid.Row="2"
            Grid.ColumnSpan="2"
            Orientation="Vertical"
            HorizontalAlignment="Center">

            <TextBlock
                x:Name="TimeText"
                Text="00:00 / 00:00"
                FontSize="18"
                HorizontalAlignment="Center"
                Margin="0,0,0,10"/>

            <StackPanel
                Orientation="Horizontal"
                HorizontalAlignment="Center">

                <Button
                    Content="⏮ -10s"
                    Width="80"
                    Margin="5"
                    Click="Back10_Click"/>

                <Button
                    Content="▶ Play"
                    Width="90"
                    Margin="5"
                    Click="Play_Click"/>

                <Button
                    Content="⏸ Pause"
                    Width="90"
                    Margin="5"
                    Click="Pause_Click"/>

                <Button
                    Content="⏹ Stop"
                    Width="90"
                    Margin="5"
                    Click="Stop_Click"/>

                <Button
                    Content="+10s ⏭"
                    Width="80"
                    Margin="5"
                    Click="Forward10_Click"/>

            </StackPanel>

        </StackPanel>

    </Grid>

</Window>